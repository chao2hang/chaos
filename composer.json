{
    "name":  "nopj/chaos",
    "description":  "The weird Flarum theme ",
    "keywords":  [
                     "flarum"
                 ],
    "type":  "flarum-extension",
    "license":  "MIT",
    "funding":  [
                    {
                        "type":  "other",
                        "url":  "https://nopj.cn"
                    }
                ],
    "require":  {
                    "flarum/core":  "^1.8.0",
                    "afrux/flarum-theme-base":  "^0.1.0"
                },
    "require-dev":  {
                        "sycho/flarum-uikit":  "0.1.x-dev",
                        "afrux/flarum-theme-base":  "0.1.x-dev"
                    },
    "authors":  [
                    {
                        "name":  "Chaos",
                        "email":  "chaos@nopj.cn",
                        "role":  "Developer"
                    }
                ],
    "support":  {
                    "forum":  "https://nopj.cn"
                },
    "autoload":  {
                     "psr-4":  {
                                   "Nopj\\Chaos\\":  "src/"
                               }
                 },
    "autoload-dev":  {
                         "psr-4":  {
                                       "Nopj\\Chaos\\Tests\\":  "tests/"
                                   }
                     },
    "extra":  {
                  "branch-alias":  {
                                       "dev-master":  "0.1.x-dev"
                                   },
                  "flarum-extension":  {
                                           "title":  "Chaos",
                                           "category":  "theme",
                                           "optional-dependencies":  [
                                                                         "flarum/tags",
                                                                         "flarum/approval",
                                                                         "sycho/flarum-advanced-extension-categories"
                                                                     ],
                                           "icon":  {
                                                        "image":  "icon.png"
                                                    }
                                       },
                  "flarum-cli":  {
                                     "modules":  {
                                                     "admin":  true,
                                                     "forum":  true,
                                                     "js":  true,
                                                     "jsCommon":  false,
                                                     "css":  true,
                                                     "gitConf":  true,
                                                     "githubActions":  true,
                                                     "prettier":  true,
                                                     "typescript":  true,
                                                     "bundlewatch":  false,
                                                     "backendTesting":  false,
                                                     "editorConfig":  true,
                                                     "styleci":  true
                                                 }
                                 }
              }
}